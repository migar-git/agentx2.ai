# AgentX2.ai — environment template (NO SECRETS). Copy to `.env` and fill locally.
# Governance: docs/KEY_MANAGEMENT.md · docs/API_CONTRACTS.md
# .env is git-ignored. Never commit real secrets. CI runs secret scanning.

# ---- Site (build-time) ----
SITE_BASE_URL=https://agentx2.ai
# Public, privacy-respecting analytics endpoint (optional; no external calls if unset).
PUBLIC_ANALYTICS_ENDPOINT=
PUBLIC_ANALYTICS_ID=

# ---- Local models (default, local-first) ----
OLLAMA_HOST=http://localhost:11434

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
OTEL_SERVICE_NAME=agentx2-web

# ---- Optional cloud model providers (only if/when enabled; least privilege) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=

# ---- Platform integrations (future private platform) ----
GITHUB_TOKEN=
CRM_API_KEY=
EMAIL_API_KEY=
VECTOR_DB_URL=

# ---- Platform API auth (future private platform) ----
JWT_SIGNING_KEY=
API_KEY=
