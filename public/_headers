# Security headers for hosts that honor a _headers file (Cloudflare Pages, Netlify).
# NOTE: GitHub Pages does not apply custom headers; deploy behind Cloudflare/Netlify
# (or a reverse proxy) to enforce these. Docs: docs/06-governance/SECURITY_ARCHITECTURE.md
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'
