---
/**
 * BaseLayout — the page shell: head, skip-link, header, main, footer, AI widget.
 */
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AIWidget from '../components/AIWidget.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
  ogType?: string;
  image?: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  agent?: string;
  mission?: string;
  aiPage?: string;
  starters?: string[];
}

const {
  title,
  description,
  path = '/',
  ogType,
  image,
  schema,
  noindex,
  agent,
  mission,
  aiPage,
  starters,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} path={path} ogType={ogType} image={image} schema={schema} noindex={noindex} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header path={path} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    {agent && <AIWidget agent={agent} mission={mission ?? ''} page={aiPage ?? path} starters={starters} />}
  </body>
</html>
