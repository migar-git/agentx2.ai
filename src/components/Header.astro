---
/**
 * Header — global navigation. Exposes every top-level destination from every page,
 * with a mobile menu, theme toggle, and primary CTA. ≤3-click guarantee.
 */
import { NAV, SITE } from '../data/site';

interface Props {
  path?: string;
}
const { path = '' } = Astro.props;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/" aria-label={`${SITE.name} home`}>
      <svg class="mark" viewBox="0 0 32 32" aria-hidden="true" fill="none">
        <defs>
          <linearGradient id="bg-grad" x1="0" y1="0" x2="32" y2="32">
            <stop offset="0" stop-color="#6ea8fe" />
            <stop offset="1" stop-color="#8b7bff" />
          </linearGradient>
        </defs>
        <rect x="1" y="1" width="30" height="30" rx="9" fill="url(#bg-grad)" />
        <path d="M9 22 L16 9 L23 22 M11.6 17.4 H20.4" stroke="#06080d" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      <span>AgentX2<span style="color:var(--accent)">.ai</span></span>
    </a>

    <button class="nav-toggle" id="navToggle" aria-expanded="false" aria-controls="navMenu" aria-label="Open menu">☰</button>

    <div class="nav-spacer"></div>

    <div class="nav-menu" id="navMenu">
      <nav aria-label="Primary">
        <ul class="nav-list">
          {
            NAV.map((item) => (
              <li>
                <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div class="nav-actions">
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle color theme" title="Toggle theme">
          <span aria-hidden="true">◐</span>
        </button>
        <a class="btn btn-primary" href="/contact/" data-ax2-event="cta_click" data-ax2-label="header_contact">Book a consult</a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    var toggle = document.getElementById('navToggle');
    var menu = document.getElementById('navMenu');
    if (toggle && menu) {
      toggle.addEventListener('click', function () {
        var open = menu.getAttribute('data-open') === 'true';
        menu.setAttribute('data-open', String(!open));
        toggle.setAttribute('aria-expanded', String(!open));
        toggle.setAttribute('aria-label', !open ? 'Close menu' : 'Open menu');
      });
    }
    var theme = document.getElementById('themeToggle');
    if (theme) {
      theme.addEventListener('click', function () {
        var current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        var next = current === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        try {
          localStorage.setItem('ax2-theme', next);
        } catch (e) {}
        if (window.ax2) window.ax2.track('theme_toggle', { theme: next });
      });
    }
  })();
</script>
